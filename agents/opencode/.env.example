# OpenCode NATS channel local environment template.
# Copy to .env for local development if your shell/tooling loads dotenv files.
# Keep real credentials out of git; this file contains paths and harmless defaults only.

# Optional config file override.
# SYNADIA_OPENCODE_CONFIG=$HOME/.config/synadia/opencode-nats-channel.toml

# Pick one NATS connection path. Prefer a named NATS CLI context when available.
NATS_CONTEXT=local
# NATS_URL=nats://127.0.0.1:4222
# NATS_CREDS=/path/to/user.creds

# Synadia Agent Protocol identity.
SYNADIA_OPENCODE_OWNER=local
SYNADIA_OPENCODE_SESSION=main

# Plugin mode: install .opencode/plugins/synadia-channel.ts, set the identity
# above, and start OpenCode. If SYNADIA_OPENCODE_SESSION is unset, the plugin
# derives a session-<hash> token instead of exposing local path names.
SYNADIA_OPENCODE_HEARTBEAT_INTERVAL_S=30
SYNADIA_OPENCODE_KEEPALIVE_INTERVAL_S=30
OPENCODE_PERMISSION_TIMEOUT_MS=300000

# External managed mode: leave OPENCODE_SERVER_URL unset and let the adapter manage opencode serve.
OPENCODE_HOSTNAME=127.0.0.1
OPENCODE_PORT=4096
OPENCODE_DIRECTORY=/path/to/repo
# OPENCODE_WORKSPACE=
# OPENCODE_MODEL=provider/model
# OPENCODE_AGENT=build
OPENCODE_PERMISSION_POLICY=query

# Attached mode: set this when connecting to an existing opencode serve process.
# OPENCODE_SERVER_URL=http://127.0.0.1:4096
# OPENCODE_SESSION_ID=ses_example
# OPENCODE_SERVER_PASSWORD=
