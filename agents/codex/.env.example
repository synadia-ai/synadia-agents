# NATS connection
NATS_URL=nats://127.0.0.1:4222
# NATS_CONTEXT=
# NATS_CREDS=

# Public protocol identity. These become subject tokens, so keep them lowercase
# alphanumeric plus '-' or '_'. Do not use raw Codex thread IDs or endpoint paths.
SYNADIA_CODEX_OWNER=local
SYNADIA_CODEX_SESSION=main

# Runtime mode: fake, managed, attached, or manager.
SYNADIA_CODEX_MODE=managed
SYNADIA_CODEX_PERMISSION_POLICY=reject

# Attached mode requires an explicit endpoint, private thread id, and safe alias.
# Manager mode may list multiple endpoints in SYNADIA_CODEX_MANAGER_ENDPOINTS,
# but SYNADIA_CODEX_ENDPOINT_AUTH is a single shared token for all configured
# endpoints. Use the programmatic EndpointRegistry API when endpoints need
# distinct auth tokens.
# SYNADIA_CODEX_ENDPOINT=unix:///path/to/codex.sock
# SYNADIA_CODEX_ENDPOINT_AUTH=
# SYNADIA_CODEX_THREAD_ID=
# SYNADIA_CODEX_PUBLIC_ALIAS=demo
