{
  "name": "@synadia-ai/nats-codex-channel",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Synadia Agent Protocol for NATS bridge for @zed-industries/codex-acp — exposes a Codex CLI session over ACP on agents.prompt.codex.<owner>.<session>.",
  "bin": {
    "nats-codex-channel": "./src/cli.ts"
  },
