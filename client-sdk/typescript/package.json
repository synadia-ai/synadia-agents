{
  "name": "@synadia-ai/agents",
  "version": "0.5.0",
  "description": "TypeScript SDK for the NATS Agent Protocol — discover, prompt, and stream from AI agents over NATS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs",
      "default": "./dist/errors.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "docs": "typedoc",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nats",
    "ai",
    "agents",
    "agent-protocol",
    "synadia",
    "sdk",
    "llm",
    "streaming"
  ],
  "license": "Apache-2.0",
  "author": "Synadia Communications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synadia-ai/synadia-agents.git",
    "directory": "client-sdk/typescript"
  },
  "homepage": "https://github.com/synadia-ai/synadia-agents/tree/main/client-sdk/typescript",
  "bugs": {
    "url": "https://github.com/synadia-ai/synadia-agents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nats-io/nats-core": "^3.3.0",
    "@nats-io/services": "^3.3.0",
    "@nats-io/transport-node": "^3.3.0"
  },
  "devDependencies": {
    "@synadia-ai/agent-service": "file:../../agent-sdk/typescript",
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typedoc": "^0.26.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^3.2.0"
  }
}
