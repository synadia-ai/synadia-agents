    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@nats-io/transport-node": "^3.3.1",
    "@synadia-ai/agents": "file:../../client-sdk/typescript"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "typescript": "^5.6.0",
    "vite": "^7.2.4",
    "vue": "^3.5.24",
    "vue-tsc": "^2.1.10"
  }
}
